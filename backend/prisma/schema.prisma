generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider     = "postgresql"
  url          = env("DATABASE_URL")
  relationMode = "prisma"
}

// ===== ENUMS =====

enum UserType {
  CITIZEN
  STAFF
}

enum Gender {
  MALE
  FEMALE
  OTHER
}

enum StaffRole {
  SUPER_ADMIN
  CHAIRMAN
  HOD
  CLERK
  VERIFIER
  ACCOUNT_OFFICER
  AUDITOR
  SUPPORT
}

enum ApplicationType {
  IDENTIFICATION_CERTIFICATE
  BIRTH_CERTIFICATE
  BUSINESS_PREMISES
  LOCAL_TAX_CLEARANCE
  TENEMENT_RATE
  OTHER
}

enum ApplicationStatus {
  DRAFT
  SUBMITTED
  PAYMENT_PENDING
  PAYMENT_CONFIRMED
  UNDER_REVIEW
  PENDING_VERIFICATION
  VERIFIED
  APPROVED
  REJECTED
  CANCELLED
  ISSUED
  REVOKED
}

enum VerificationStatus {
  NOT_STARTED
  PENDING
  IN_REVIEW
  VERIFIED
  FAILED
  REJECTED
}

enum PaymentStatus {
  PENDING
  INITIATED
  PROCESSING
  SUCCESS
  FAILED
  REFUNDED
  PARTIALLY_REFUNDED
  CANCELLED
}

enum PaymentProvider {
  FLUTTERWAVE
  PAYSTACK
  MANUAL
  BANK_TRANSFER
}

enum CertificateStatus {
  ACTIVE
  REVOKED
  EXPIRED
  VOIDED
}

enum DocumentType {
  PASSPORT_PHOTO
  NIN_SLIP
  BIRTH_CERTIFICATE
  AGE_DECLARATION
  UTILITY_BILL
  COMMUNITY_LETTER
  APPLICATION_ATTACHMENT
  PAYMENT_RECEIPT
  OTHER
}

enum ReviewDecision {
  PENDING
  APPROVED
  REJECTED
  NEEDS_CORRECTION
}

enum DeliveryChannel {
  EMAIL
  SMS
  WHATSAPP
  SYSTEM
}

enum NotificationStatus {
  PENDING
  SENT
  FAILED
  READ
}

enum OtpType {
  EMAIL_VERIFICATION
  PHONE_VERIFICATION
  PASSWORD_RESET
}

enum MessageCategory {
  GENERAL
  COMPLAINT
  SUGGESTION
  COMMENDATION
  REPORT
  OTHER
}

enum MessageStatus {
  RECEIVED
  UNDER_REVIEW
  ACKNOWLEDGED
  RESOLVED
  CLOSED
}

// ===== CORE MODELS =====

model Ward {
  id        String   @id @default(cuid())
  name      String   @unique
  code      String?  @unique
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  users        User[]
  addresses    Address[]
  applications Application[]

  @@map("wards")
}

model User {
  id       String   @id @default(cuid())
  wardId   String?  @map("ward_id")
  userType UserType @default(CITIZEN) @map("user_type")

  // Identity fields
  //firstName             String
  // middleName            String?
  //lastName              String
  fullName           String?   @map("full_name")
  email              String?   @unique
  phone              String    @unique
  alternatePhone     String?   @map("alternate_phone")
  passwordHash       String?   @map("password_hash")
  gender             Gender?
  dateOfBirth        DateTime? @map("date_of_birth")
  nin                String?   @unique
  nationalIdVerified Boolean   @default(false) @map("national_id_verified")

  // Address & origin
  occupation      String?
  placeOfBirth    String? @map("place_of_birth")
  stateOfOrigin   String? @map("state_of_origin")
  lgaOfOrigin     String? @map("lga_of_origin")
  nationality     String? @default("Nigerian")
  profilePhotoUrl String? @map("profile_photo_url")

  // Password reset fields
  resetTokenHash   String?   @map("reset_token_hash")
  resetTokenExpiry DateTime? @map("reset_token_expiry")

  // Account status
  isActive        Boolean   @default(true) @map("is_active")
  isPhoneVerified Boolean   @default(false) @map("is_phone_verified")
  isEmailVerified Boolean   @default(false) @map("is_email_verified")
  lastLoginAt     DateTime? @map("last_login_at")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  // Relations
  ward                  Ward?               @relation(fields: [wardId], references: [id], onDelete: SetNull)
  addresses             Address[]
  staffProfile          StaffProfile?
  applications          Application[]       @relation("ApplicantApplications")
  submittedApplications Application[]       @relation("ApplicationSubmitter")
  reviews               ApplicationReview[]
  certificatesIssued    Certificate[]       @relation("CertificateIssuedBy")
  auditLogs             AuditLog[]
  notifications         Notification[]
  uploads               UploadedDocument[]
  otpCodes              OtpCode[]

  @@index([wardId])
  @@index([phone])
  @@index([email])
  @@index([nin])
  @@map("users")
}

model StaffProfile {
  id                     String    @id @default(cuid())
  userId                 String    @unique @map("user_id")
  employeeCode           String?   @unique @map("employee_code")
  role                   StaffRole
  department             String?
  signatureImageUrl      String?   @map("signature_image_url")
  canApproveCertificates Boolean   @default(false) @map("can_approve_certificates")
  canVerifyApplications  Boolean   @default(false) @map("can_verify_applications")
  canManagePayments      Boolean   @default(false) @map("can_manage_payments")
  canManageSettings      Boolean   @default(false) @map("can_manage_settings")
  canViewAuditLogs       Boolean   @default(false) @map("can_view_audit_logs")
  createdAt              DateTime  @default(now()) @map("created_at")
  updatedAt              DateTime  @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([role])
  @@map("staff_profiles")
}

model OtpCode {
  id        String    @id @default(cuid())
  userId    String    @map("user_id")
  code      String
  type      OtpType
  attempts  Int       @default(0)
  expiresAt DateTime  @map("expires_at")
  isUsed    Boolean   @default(false) @map("is_used")
  usedAt    DateTime? @map("used_at")
  createdAt DateTime  @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([code])
  @@index([expiresAt])
  @@map("otp_codes")
}

model Address {
  id         String   @id @default(cuid())
  userId     String?  @map("user_id")
  wardId     String?  @map("ward_id")
  line1      String
  line2      String?
  city       String?
  state      String
  postalCode String?  @map("postal_code")
  country    String   @default("Nigeria")
  landmark   String?
  isPrimary  Boolean  @default(false) @map("is_primary")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  user         User?         @relation(fields: [userId], references: [id], onDelete: Cascade)
  ward         Ward?         @relation(fields: [wardId], references: [id], onDelete: SetNull)
  applications Application[]

  @@index([userId])
  @@index([wardId])
  @@map("addresses")
}

// ===== SERVICE & APPLICATION MODELS =====

model ServiceConfig {
  id                      String          @id @default(cuid())
  serviceType             ApplicationType @map("service_type")
  name                    String
  slug                    String
  description             String?
  feeInNaira               BigInt          @map("fee_in_naira")
  processingDays          Int?            @map("processing_days")
  requiresNin             Boolean?         @default(false) @map("requires_nin")
  requiresPassport        Boolean?         @default(true) @map("requires_passport")
  requiresCommunityLetter Boolean?        @default(false) @map("requires_community_letter")
  requiresBirthDocument   Boolean?         @default(false) @map("requires_birth_document")
  requiresAddressProof    Boolean?         @default(false) @map("requires_address_proof")
  requiresManualApproval  Boolean?         @default(true) @map("requires_manual_approval")
  validityDays            Int?            @map("validity_days")
  prefix                  String?
  templateName            String?         @map("template_name")
  certificateTitle        String?         @map("certificate_title")
  isActive                Boolean         @default(true) @map("is_active")
  createdAt               DateTime        @default(now()) @map("created_at")
  updatedAt               DateTime        @updatedAt @map("updated_at")

  applications Application[]

  @@unique([serviceType])
  @@index([slug])
  @@map("service_configs")
}

model ApplicationSequence {
  id          String          @id @default(cuid())
  serviceType ApplicationType @map("service_type")
  year        Int
  sequenceNum BigInt          @map("sequence_num")
  lastUsedAt  DateTime        @default(now()) @map("last_used_at")
  createdAt   DateTime        @default(now()) @map("created_at")
  updatedAt   DateTime        @updatedAt @map("updated_at")

  @@unique([serviceType, year])
  @@map("application_sequences")
}

model Application {
  id                 String             @id @default(cuid())
  serviceConfigId    String             @map("service_config_id")
  applicantId        String             @map("applicant_id")

 //user  @relation('userId', fields:[userId], references:[id], onDelete:Cascade)

//userId String @map('user_id')
  submittedByUserId  String?            @map("submitted_by_user_id")
  addressId          String?            @map("address_id")
  refNumber          String             @unique @map("ref_number")
  status             ApplicationStatus  @default(DRAFT)
  verificationStatus VerificationStatus @default(NOT_STARTED) @map("verification_status")
  paymentStatus      PaymentStatus      @default(PENDING) @map("payment_status")
  reviewDecision     ReviewDecision     @default(PENDING) @map("review_decision")

  // Application data
  applicationData   Json?              @map("application_data")
  attachedDocuments UploadedDocument[]

  // Metadata
  submittedAt DateTime? @map("submitted_at")
  approvedAt  DateTime? @map("approved_at")
  issuedAt    DateTime? @map("issued_at")
  expiresAt   DateTime? @map("expires_at")
  notes       String?

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  serviceConfig ServiceConfig       @relation(fields: [serviceConfigId], references: [id])
  applicant     User                @relation("ApplicantApplications", fields: [applicantId], references: [id], onDelete: Cascade)
  submittedBy   User?               @relation("ApplicationSubmitter", fields: [submittedByUserId], references: [id], onDelete: SetNull)
  address       Address?            @relation(fields: [addressId], references: [id], onDelete: SetNull)
  reviews       ApplicationReview[]
  payments      Payment[]
  certificate   Certificate?
  Ward          Ward?               @relation(fields: [wardId], references: [id])
  wardId        String?

  @@index([applicantId])
  @@index([serviceConfigId])
  @@index([status])
  @@index([refNumber])
  @@map("applications")
}

model ApplicationReview {
  id               String         @id @default(cuid())
  applicationId    String         @map("application_id")
  reviewedByUserId String         @map("reviewed_by_user_id")
  decision         ReviewDecision
  comments         String?
  findingsData     Json?          @map("findings_data")
  reviewedAt       DateTime       @default(now()) @map("reviewed_at")
  createdAt        DateTime       @default(now()) @map("created_at")
  updatedAt        DateTime       @updatedAt @map("updated_at")

  application Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  reviewedBy  User        @relation(fields: [reviewedByUserId], references: [id])

  @@index([applicationId])
  @@index([reviewedByUserId])
  @@map("application_reviews")
}

// ===== PAYMENT & CERTIFICATE MODELS =====

model Payment {
  id              String          @id @default(cuid())
  applicationId   String          @map("application_id")
  referenceNumber String          @unique @map("reference_number")
  amountInKobo    BigInt          @map("amount_in_kobo")
  provider        PaymentProvider
  status          PaymentStatus   @default(PENDING)
  transactionId   String?         @unique @map("transaction_id")
  metadata        Json?

  initiatedAt   DateTime  @default(now()) @map("initiated_at")
  completedAt   DateTime? @map("completed_at")
  failureReason String?   @map("failure_reason")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  application Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)

  @@index([applicationId])
  @@index([referenceNumber])
  @@index([transactionId])
  @@index([status])
  @@map("payments")
}

model Certificate {
  id                String            @id @default(cuid())
  applicationId     String            @unique @map("application_id")
  certificateNumber String            @unique @map("certificate_number")
  issuedByUserId    String            @map("issued_by_user_id")
  status            CertificateStatus @default(ACTIVE)

  // Certificate content
  certificateData Json    @map("certificate_data") // Stores generated certificate data
  certificateUrl  String? @map("certificate_url") // URL to PDF/image

  // Validity tracking
  issuedAt         DateTime  @default(now()) @map("issued_at")
  expiresAt        DateTime? @map("expires_at")
  revokedAt        DateTime? @map("revoked_at")
  revocationReason String?   @map("revocation_reason")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  application Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  issuedBy    User        @relation("CertificateIssuedBy", fields: [issuedByUserId], references: [id])

  @@index([certificateNumber])
  @@index([status])
  @@map("certificates")
}

// ===== DOCUMENT & NOTIFICATION MODELS =====

model UploadedDocument {
  id            String       @id @default(cuid())
  userId        String?      @map("user_id")
  applicationId String?      @map("application_id")
  documentType  DocumentType @map("document_type")
  fileName      String       @map("file_name")
  fileUrl       String       @map("file_url")
  fileSize      Int          @map("file_size")
  mimeType      String       @map("mime_type")

  uploadedAt DateTime @default(now()) @map("uploaded_at")
  createdAt  DateTime @default(now()) @map("created_at")

  user        User?        @relation(fields: [userId], references: [id], onDelete: Cascade)
  application Application? @relation(fields: [applicationId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([applicationId])
  @@map("uploaded_documents")
}

model Notification {
  id      String             @id @default(cuid())
  userId  String             @map("user_id")
  title   String
  message String
  channel DeliveryChannel
  status  NotificationStatus @default(PENDING)

  relatedEntityId   String? @map("related_entity_id")
  relatedEntityType String? @map("related_entity_type")

  sentAt    DateTime? @map("sent_at")
  readAt    DateTime? @map("read_at")
  createdAt DateTime  @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status])
  @@map("notifications")
}

// ===== AUDIT & SYSTEM MODELS =====

model AuditLog {
  id         String  @id @default(cuid())
  userId     String? @map("user_id")
  action     String
  entityType String  @map("entity_type")
  entityId   String  @map("entity_id")
  changes    Json?
  ipAddress  String? @map("ip_address")
  userAgent  String? @map("user_agent")

  createdAt DateTime @default(now()) @map("created_at")

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([action])
  @@index([createdAt])
  @@map("audit_logs")
}

model SystemSetting {
  id          String  @id @default(cuid())
  key         String  @unique
  value       String
  description String?

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("system_settings")
}

model Announcement {
  id       String  @id @default(cuid())
  title    String
  content  String
  imageUrl String? @map("image_url")
  isActive Boolean @default(true) @map("is_active")

  publishedAt DateTime? @map("published_at")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  @@index([publishedAt])
  @@map("announcements")
}

model AnonymousMessage {
  id          String           @id @default(cuid())
  userId      String?          @map("user_id")
  fullName    String?          @map("full_name")
  email       String?
  phone       String?
  message     String
  category    MessageCategory  @default(GENERAL)
  status      MessageStatus    @default(RECEIVED)
  ipAddress   String?          @map("ip_address")
  userAgent   String?          @map("user_agent")
  reviewedBy  String?          @map("reviewed_by")
  reviewNote  String?          @map("review_note")
  reviewedAt  DateTime?        @map("reviewed_at")
  submittedAt DateTime         @default(now()) @map("submitted_at")
  createdAt   DateTime         @default(now()) @map("created_at")
  updatedAt   DateTime         @updatedAt @map("updated_at")

  @@index([category])
  @@index([status])
  @@index([submittedAt])
  @@map("anonymous_messages")
}
